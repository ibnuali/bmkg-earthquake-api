# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_READ_TIMEOUT=10s
SERVER_WRITE_TIMEOUT=30s
SERVER_IDLE_TIMEOUT=60s

# BMKG
BMKG_BASE_URL=https://data.bmkg.go.id
BMKG_JSON_ENDPOINT=/DataMKG/TEWS
BMKG_SHAKEMAP_URL=https://static.bmkg.go.id
BMKG_HTTP_TIMEOUT=10s
BMKG_MAX_RETRIES=2
BMKG_RETRY_WAIT=500ms

# Cache
CACHE_ENABLED=true
CACHE_TTL=30s
CACHE_CLEANUP_INTERVAL=60s

# CORS
CORS_ALLOWED_ORIGINS=*
